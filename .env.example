# muster BYOM (bring-your-own-model) credentials — copy to .env and fill in.
# .env is gitignored; never commit a real key.
#
# muster reads the API key from MUSTER_API_KEY (fallback OPENAI_API_KEY) at
# request time. Base URL and model are passed as CLI flags, not env vars:
#   node --env-file=.env dist/cli/index.js behave run <suite>.yaml \
#        --base-url https://api.openai.com/v1 --model gpt-4o-mini
#
# Node 22 loads this file natively with --env-file=.env (no dotenv dependency).

# Required: your OpenAI (or any OpenAI-compatible) API key.
MUSTER_API_KEY=<paste-your-api-key-here>

# Optional convenience defaults for local smoke runs (the smoke step / scripts
# may read these; the CLI itself still takes --base-url / --model flags).
MUSTER_BASE_URL=https://api.openai.com/v1
MUSTER_MODEL=gpt-4o-mini
