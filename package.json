{
  "name": "@garrison-hq/muster",
  "version": "0.0.0",
  "description": "Conformance harness for the agent-file stack — static validation and behavioral grading across Soul.md personas (RFC-1/CTS-1), Agent Skills, OpenClaw SOPs (AGENTS.md), tool manifests (TOOLS.md), agent memory, heartbeat checklists, cross-layer composition, and A2A Agent Cards.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jeroen Nouws",
  "homepage": "https://garrison-hq.github.io/muster",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garrison-hq/muster.git"
  },
  "bugs": {
    "url": "https://github.com/garrison-hq/muster/issues"
  },
  "keywords": [
    "conformance",
    "conformance-testing",
    "ai-agents",
    "agent-file",
    "llm",
    "behavioral-testing",
    "soul.md",
    "soulmd",
    "rfc-1",
    "cts-1",
    "persona",
    "agent-skills",
    "skill.md",
    "sop",
    "agents.md",
    "tools.md",
    "memory",
    "heartbeat",
    "cross-layer",
    "a2a",
    "agent-card",
    "agent2agent",
    "json-schema",
    "canonical-json",
    "rfc8785",
    "cli"
  ],
  "bin": {
    "muster": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src",
    "cts",
    "souls",
    "behave/voice-frontdesk.yaml",
    "examples",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.27.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').copyFileSync('src/adapters/rfc1/schema.json','dist/adapters/rfc1/schema.json')\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/index.ts",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^14.0.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.19.11",
    "@vitest/coverage-v8": "^3.2.6",
    "semantic-release": "^25.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
